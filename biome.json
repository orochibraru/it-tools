            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["*.test.ts", "*.test.js", "*.spec.ts", "*.spec.js"],
      "linter": {
        "rules": {
          "suspicious": {
            "noUnusedExpressions": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.md/*.*"],
      "linter": {
        "rules": {
          "correctness": {
            "noInvalidUseBeforeDeclaration": "off",
            "noUndeclaredVariables": "off",
            "noUnusedImports": "off",
            "noUnusedVariables": "off"
          },
          "style": {
            "noCommonJs": "off",
            "noNamespace": "off",
            "noRestrictedImports": "off"
          },
