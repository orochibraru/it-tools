      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off"
          },
          "suspicious": {
            "noUnusedExpressions": "off"
          }
        }
      }
    },
    {
      "includes": ["*.yaml", "*.yml"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off"
          },
          "suspicious": {
            "noIrregularWhitespace": "off"
          }
        }
      }
