  "html": {
    "formatter": {
      "indentScriptAndStyle": true,
      "selfCloseVoidElements": "always"
    }
  },
  "overrides": [
    {
      "includes": ["**/*.svelte", "**/*.astro", "**/*.vue"],
      "linter": {
        "rules": {
          "style": {
            "useConst": "off",
            "useImportType": "off"
          },
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["*.vue"],
      "linter": {
        "rules": {
          "correctness": {
            "noUndeclaredVariables": "off",
            "noUnusedVariables": "off"
          }
        }
      }
    },
    {
      "includes": ["*.json", "*.json5", "*.jsonc"],
      "linter": {
        "rules": {}
      }
    },
    {
      "includes": ["*.yaml", "*.yml"],
      "linter": {
        "rules": {}
      }
    },
    {
      "includes": ["package.json"],
      "linter": {
        "rules": {}
      }
    },
    {
      "includes": ["*.d.ts"],
      "linter": {
        "rules": {}
      }
    },
    {
      "includes": ["*.js", "*.cjs", "*.jsx"],
      "linter": {
        "rules": {
          "style": {
            "noCommonJs": "off"
          }
        }
      }
    },
    {
      "includes": ["*.ts", "*.tsx", "*.mts", "*.cts"],
      "linter": {
        "rules": {
          "complexity": {
            "noVoid": "error"
          }
        }
      }
    },
    {
      "includes": ["scripts/**/*.*", "cli.*"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["*.test.ts", "*.test.js", "*.spec.ts", "*.spec.js"],
      "linter": {
        "rules": {
          "suspicious": {
            "noUnusedExpressions": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.md/*.*"],
      "linter": {
        "rules": {
          "correctness": {
            "noInvalidUseBeforeDeclaration": "off",
            "noUndeclaredVariables": "off",
            "noUnusedImports": "off",
            "noUnusedVariables": "off"
          },
          "style": {
            "noCommonJs": "off",
            "noNamespace": "off",
            "noRestrictedImports": "off"
          },
          "suspicious": {
            "noAlert": "off",
            "noConsole": "off",
            "noRedeclare": "off",
            "noUnusedExpressions": "off"
          }
        }
      }
    },
    {
      "includes": ["*.json", "*.json5", "*.jsonc"],
      "linter": {
        "rules": {}
      }
    },
    {
      "includes": ["*.yaml", "*.yml"],
      "linter": {
        "rules": {}
      }
    },
    {
      "includes": ["package.json"],
      "linter": {
        "rules": {}
      }
    },
    {
      "includes": ["*.d.ts"],
      "linter": {
        "rules": {}
      }
    },
    {
      "includes": ["*.js", "*.cjs", "*.jsx"],
